{
  "rewrites": [
    {
      "source": "/api/auth/filho-login",
      "destination": "/api/auth/filho-login"
    },
    {
      "source": "/api/tenant-info",
      "destination": "/api/tenant-info"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
